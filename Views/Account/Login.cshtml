@model FarmaciaInventario.Controllers.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - PharmaCore</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body {
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
        }
        .login-card {
            width: 100%;
            max-width: 400px;
        }
        .bi {
            font-family: 'bootstrap-icons' !important;
            font-size: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="text-center mb-4">
            <div class="display-4 text-primary mb-2"><i class="bi bi-capsule-pill"></i></div>
            <h2 class="fw-bold">PHARMA<span class="text-primary">CORE</span></h2>
            <p class="small" style="color: #94a3b8;">Gestión de Inventario y Ventas</p>
        </div>

        <div class="glass-card">
            <h4 class="fw-bold mb-4">Iniciar Sesión</h4>
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                
                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-bold" style="color: #94a3b8;">CORREO ELECTRÓNICO</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25" style="color: #94a3b8;"><i class="bi bi-envelope"></i></span>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary border-opacity-25" placeholder="admin@farmacia.com" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label small fw-bold" style="color: #94a3b8;">CONTRASEÑA</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-opacity-25" style="color: #94a3b8;"><i class="bi bi-lock"></i></span>
                        <input asp-for="Password" class="form-control bg-dark text-white border-secondary border-opacity-25" type="password" placeholder="••••••••" />
                    </div>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input bg-dark border-secondary" />
                    <label asp-for="RememberMe" class="form-check-label small" style="color: #94a3b8;">Recordarme en este equipo</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow">
                    ENTRAR AL SISTEMA
                </button>
            </form>
        </div>

        <div class="mt-5 text-center small" style="color: #64748b;">
            <p style="color: #94a3b8;">Accesos por defecto:</p>
            <p class="mb-1"><strong>Admin:</strong> admin@farmacia.com / Admin123*</p>
            <p><strong>Vendedor:</strong> vendedor@farmacia.com / User123*</p>
        </div>
    </div>
</body>
</html>
