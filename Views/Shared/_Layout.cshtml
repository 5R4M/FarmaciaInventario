<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Farmacia Inventario</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark mb-4">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-capsule-pill me-2 text-emerald"></i>PHARMA<span class="text-primary">CORE</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Sales" asp-action="Create">
                                    <i class="bi bi-receipt me-1"></i>Facturación
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Products" asp-action="Index">
                                    <i class="bi bi-box-seam me-1"></i>Inventario
                                </a>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-warning" asp-controller="Categories" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i>Categorías
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-info" asp-controller="Sales" asp-action="Reports">
                                        <i class="bi bi-graph-up me-1"></i>Reportes
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-emerald" asp-controller="Users" asp-action="Index">
                                        <i class="bi bi-people me-1"></i>Usuarios
                                    </a>
                                </li>
                            }

                            <li class="nav-item ms-lg-3 dropdown">
                                <a class="nav-link dropdown-toggle bg-dark bg-opacity-25 rounded-pill px-3 border border-secondary border-opacity-25" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1 text-primary"></i> 
                                    <span class="small">@User.Identity.Name</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg border-secondary border-opacity-25">
                                    <li><span class="dropdown-item-text small text-muted">Rol: @(User.IsInRole("Admin") ? "Administrador" : "Usuario")</span></li>
                                    <li><hr class="dropdown-divider border-secondary border-opacity-25"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline w-100">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-primary px-4" asp-controller="Account" asp-action="Login">Iniciar Sesión</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 py-4 text-center text-muted border-top border-secondary border-opacity-25">
        <div class="container">
            &copy; 2026 - PharmaCore System - Gestión de Inventario
        </div>
    </footer>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
