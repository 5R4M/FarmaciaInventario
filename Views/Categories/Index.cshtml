@model IEnumerable<FarmaciaInventario.Models.Category>

@{
    ViewData["Title"] = "Categorías de Insumos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-tags me-2 text-primary"></i>Categorías</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Nueva Categoría
    </a>
</div>

<div class="row g-4">
    @foreach (var item in Model) {
        <div class="col-md-4">
            <div class="glass-card h-100 d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h5 class="fw-bold mb-0">@item.Name</h5>
                    <i class="bi bi-tag text-primary"></i>
                </div>
                <p class="small flex-grow-1" style="color: #94a3b8;">@item.Description</p>
                <div class="mt-3 pt-3 border-top border-secondary border-opacity-25 d-flex justify-content-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light border-opacity-25 me-2">Editar</a>
                </div>
            </div>
        </div>
    }
</div>
