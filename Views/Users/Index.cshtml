@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-people me-2 text-primary"></i>Usuarios del Sistema</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-person-plus me-1"></i> Nuevo Usuario
    </a>
</div>

<div class="glass-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Usuario (Email)</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@user.Email</div>
                            <small style="color: #64748b;">ID: @user.Id</small>
                        </td>
                        <td>
                            <span class="badge bg-success bg-opacity-25 text-success">Activo</span>
                        </td>
                        <td class="text-end">
                            @if (user.Email != "admin@farmacia.com")
                            {
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" onsubmit="return confirm('¿Eliminar este usuario?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger border-opacity-25">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
