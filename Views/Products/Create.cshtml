@model FarmaciaInventario.Models.Product

@{
    ViewData["Title"] = "Nuevo Producto";
}

<div class="mb-4">
    <h2 class="fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Registrar Nuevo Insumo</h2>
    <p class="small" style="color: #94a3b8;">Completa los datos del producto o escanea el código de barras.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="glass-card">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row g-3">
                    <div class="col-md-12">
                        <label asp-for="SKU" class="form-label small fw-bold">CÓDIGO DE BARRAS (SKU)</label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-barcode text-primary"></i>
                            </span>
                            <input asp-for="SKU" class="form-control" placeholder="Escanea el producto..." id="skuInput" autofocus />
                        </div>
                        <span asp-validation-for="SKU" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Name" class="form-label small fw-bold">NOMBRE DEL PRODUCTO</label>
                        <input asp-for="Name" class="form-control" placeholder="Ej: Paracetamol 500mg" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label small fw-bold">DESCRIPCIÓN</label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label small fw-bold">CATEGORÍA</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label small fw-bold">PRECIO DE VENTA</label>
                        <div class="input-group">
                            <span class="input-group-text">Q</span>
                            <input asp-for="Price" class="form-control" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="StockQuantity" class="form-label small fw-bold">CANTIDAD INICIAL</label>
                        <input asp-for="StockQuantity" class="form-control" />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ExpirationDate" class="form-label small fw-bold">FECHA DE VENCIMIENTO</label>
                        <input asp-for="ExpirationDate" class="form-control" type="date" />
                        <span asp-validation-for="ExpirationDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save me-1"></i> Guardar Producto
                    </button>
                    <a asp-action="Index" class="btn btn-outline-light border-opacity-25">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="glass-card bg-primary bg-opacity-10 border-primary border-opacity-25">
            <h5 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-2"></i>Modo Lector</h5>
            <p class="small text-muted">El lector <strong>ZKTeco ZKB101</strong> funciona como un teclado. Asegúrate de que el cursor esté en el campo <strong>SKU</strong> al escanear.</p>
            <hr class="border-primary border-opacity-25">
            <div class="d-flex align-items-center gap-3">
                <div class="display-4 text-primary opacity-50"><i class="bi bi-keyboard"></i></div>
                <div class="small text-muted">El sistema enfocará automáticamente el campo SKU al cargar esta página.</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Auto-enfocar el campo SKU para el lector ZKTeco
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('skuInput').focus();
        });
    </script>
}
