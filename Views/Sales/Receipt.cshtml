@model FarmaciaInventario.Models.Sale

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recibo #@Model.Id.ToString("D5")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        /* ── Fondo de pantalla ───────────────────────── */
        body {
            font-family: 'Courier New', Courier, monospace;
            background: #0f172a;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px 12px;
        }

        /* ── Barra de acciones ───────────────────────── */
        .action-bar {
            width: 100%;
            max-width: 320px;
            display: flex;
            gap: 8px;
            margin-bottom: 18px;
        }

        .btn-action {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            padding: 10px 0;
            border: none;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            font-family: 'Segoe UI', system-ui, sans-serif;
            letter-spacing: .3px;
            transition: filter .15s, opacity .15s;
        }

        .btn-action:hover { filter: brightness(1.12); }

        .btn-print {
            flex: 1;
            background: linear-gradient(135deg, #10b981, #3b82f6);
            color: #fff;
        }

        .btn-close {
            width: 100px;
            background: rgba(255,255,255,.08);
            color: #94a3b8;
            border: 1px solid rgba(255,255,255,.12) !important;
        }

        .btn-close:hover { color: #f8fafc; }

        /* ── Recibo (papel) ──────────────────────────── */
        .receipt {
            width: 100%;
            max-width: 320px;
            background: #fff;
            border-radius: 10px;
            padding: 22px 20px 18px;
            box-shadow: 0 12px 48px rgba(0,0,0,.7);
            color: #111;
        }

        /* Efecto de recorte inferior */
        .receipt::after {
            content: '';
            display: block;
            height: 0;
        }

        /* ── Cabecera ────────────────────────────────── */
        .r-header {
            text-align: center;
            margin-bottom: 14px;
        }

        .r-header .brand {
            font-size: 20px;
            font-weight: 700;
            letter-spacing: 2px;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-header .brand span {
            color: #3b82f6;
        }

        .r-header .address {
            font-size: 10px;
            color: #666;
            margin-top: 3px;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-header .doc-type {
            margin-top: 10px;
            padding: 5px 0;
            border-top: 1px dashed #ccc;
            border-bottom: 1px dashed #ccc;
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 3px;
            color: #333;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        /* ── Datos del ticket ────────────────────────── */
        .r-meta {
            margin: 12px 0;
            font-size: 11px;
            line-height: 1.75;
        }

        .r-meta .row {
            display: flex;
            justify-content: space-between;
            gap: 6px;
        }

        .r-meta .lbl {
            color: #777;
            white-space: nowrap;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-meta .val {
            text-align: right;
            word-break: break-word;
        }

        /* ── Separador punteado ──────────────────────── */
        .dashed {
            border: none;
            border-top: 1px dashed #ccc;
            margin: 10px 0;
        }

        /* ── Tabla de productos ──────────────────────── */
        .r-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 11px;
        }

        .r-table thead tr {
            border-top: 1px dashed #ccc;
            border-bottom: 1px dashed #ccc;
        }

        .r-table th {
            padding: 5px 3px;
            font-size: 9px;
            font-weight: 700;
            color: #555;
            text-transform: uppercase;
            letter-spacing: .8px;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-table th:nth-child(2) { text-align: center; }
        .r-table th:last-child   { text-align: right; }

        .r-table td {
            padding: 5px 3px;
            vertical-align: top;
        }

        .r-table td:nth-child(2) { text-align: center; }
        .r-table td:last-child   { text-align: right; white-space: nowrap; }

        .r-table tbody tr:last-child td {
            padding-bottom: 8px;
        }

        /* ── Total ───────────────────────────────────── */
        .r-total {
            padding: 10px 0 6px;
            border-top: 1px dashed #ccc;
        }

        .r-total .total-row {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
        }

        .r-total .total-lbl {
            font-size: 10px;
            color: #777;
            text-transform: uppercase;
            letter-spacing: .8px;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-total .total-amount {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: .5px;
        }

        /* ── Pie de recibo ───────────────────────────── */
        .r-footer {
            text-align: center;
            margin-top: 14px;
            padding-top: 10px;
            border-top: 1px dashed #ccc;
            font-size: 10px;
            color: #888;
            line-height: 1.8;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .r-footer .thanks {
            font-size: 12px;
            font-weight: 700;
            color: #333;
            margin-bottom: 2px;
        }

        /* ── Modo embebido (iframe dentro de modal) ─── */
        body.embedded {
            background: transparent;
            padding: 0;
            min-height: unset;
        }

        body.embedded .receipt {
            border-radius: 0;
            box-shadow: none;
            max-width: 100%;
        }

        /* ── IMPRESIÓN ───────────────────────────────── */
        @@media print {
            body {
                background: white;
                display: block;
                padding: 0;
            }

            .action-bar { display: none; }

            .receipt {
                max-width: 58mm;
                width: 58mm;
                padding: 2mm;
                border-radius: 0;
                box-shadow: none;
            }

            .r-header .brand { font-size: 14px; }
            .r-total .total-amount { font-size: 14px; }
        }
    </style>
</head>
<body class="@(Context.Request.Query["embed"].ToString() == "true" ? "embedded" : "")">

    <!-- Barra de acciones (oculta en modo embebido) -->
    @if (Context.Request.Query["embed"].ToString() != "true")
    {
    <div class="action-bar">
        <button class="btn-action btn-print" onclick="window.print()">
            <i class="bi bi-printer-fill"></i> Imprimir recibo
        </button>
        <button class="btn-action btn-close" onclick="window.close()">
            <i class="bi bi-x-lg"></i> Cerrar
        </button>
    </div>
    }


    <!-- Papel del recibo -->
    <div class="receipt">

        <div class="r-header">
            <div class="brand">PHARMA<span>CORE</span></div>
            <div class="address">Calle Principal #123 &bull; Tel: 2222-3333</div>
            <div class="doc-type">RECIBO DE VENTA</div>
        </div>

        <div class="r-meta">
            <div class="row">
                <span class="lbl">Ticket</span>
                <span class="val">#@Model.Id.ToString("D5")</span>
            </div>
            <div class="row">
                <span class="lbl">Fecha</span>
                <span class="val">@Model.SaleDate.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="row">
                <span class="lbl">NIT</span>
                <span class="val">@Model.CustomerNit</span>
            </div>
            <div class="row">
                <span class="lbl">Cliente</span>
                <span class="val">@Model.CustomerName</span>
            </div>
            @if (!string.IsNullOrEmpty(Model.CustomerAddress))
            {
                <div class="row">
                    <span class="lbl">Dirección</span>
                    <span class="val">@Model.CustomerAddress</span>
                </div>
            }
        </div>

        <table class="r-table">
            <thead>
                <tr>
                    <th style="width:56%;">Descripción</th>
                    <th style="width:14%;">Cant.</th>
                    <th style="width:30%;">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.SaleDetails)
                {
                    <tr>
                        <td>@item.Product?.Name</td>
                        <td>@item.Quantity</td>
                        <td>Q @item.Subtotal.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="r-total">
            <div class="total-row">
                <span class="total-lbl">Total a pagar</span>
                <span class="total-amount">Q @Model.TotalAmount.ToString("F2")</span>
            </div>
        </div>

        <div class="r-footer">
            <div class="thanks">¡Gracias por su compra!</div>
            <div>Vuelva pronto &bull; PharmaCore @DateTime.Now.Year</div>
        </div>

    </div>

</body>
</html>
