@model IEnumerable<FarmaciaInventario.Models.Sale>
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Reporte de Ventas";

    var curShift = ViewBag.Shift as string ?? "";
    var shiftItems = new List<SelectListItem>
    {
        new SelectListItem { Value = "",        Text = "Todos los turnos",         Selected = curShift == ""        },
        new SelectListItem { Value = "Mañana",  Text = "Mañana  (06:00 – 14:00)", Selected = curShift == "Mañana"  },
        new SelectListItem { Value = "Tarde",   Text = "Tarde   (14:00 – 22:00)", Selected = curShift == "Tarde"   },
        new SelectListItem { Value = "Noche",   Text = "Noche   (22:00 – 06:00)", Selected = curShift == "Noche"   }
    };

    var total    = Model.Sum(s => s.TotalAmount);
    var count    = Model.Count();
    var promedio = count > 0 ? total / count : 0;
}

<style>
    .report-hero {
        background: linear-gradient(135deg, rgba(59,130,246,.15), rgba(16,185,129,.08));
        border: 1px solid rgba(59,130,246,.25);
        border-radius: 1rem;
        padding: 1.5rem 2rem;
        margin-bottom: 1.75rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--glass-border);
        border-radius: .875rem;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .stat-icon {
        width: 48px; height: 48px;
        border-radius: .625rem;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem; flex-shrink: 0;
    }
    .stat-icon.blue  { background: rgba(59,130,246,.15); color: #3b82f6; }
    .stat-icon.green { background: rgba(16,185,129,.15); color: #10b981; }
    .stat-icon.amber { background: rgba(245,158,11,.15);  color: #f59e0b; }
    .stat-label { font-size: .72rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
    .stat-value { font-size: 1.6rem; font-weight: 700; line-height: 1.1; color: #f8fafc; }
    .filter-card {
        background: var(--card-bg);
        border: 1px solid var(--glass-border);
        border-radius: 1rem;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
    }
    .tag-filter {
        display: inline-flex; align-items: center; gap: .4rem;
        background: rgba(59,130,246,.12);
        border: 1px solid rgba(59,130,246,.3);
        color: #93c5fd; border-radius: 9999px;
        padding: .2rem .75rem; font-size: .78rem; font-weight: 600;
    }
    .table-report thead th {
        background: rgba(15,23,42,.6);
        color: #64748b;
        font-size: .7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: .08em;
        padding: .85rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,.07) !important;
    }
    .table-report tbody td {
        padding: .85rem 1rem;
        border-bottom: 1px solid rgba(255,255,255,.05) !important;
        vertical-align: middle;
    }
    .table-report tbody tr:hover td { background: rgba(30,41,59,.6); }
    .ticket-badge {
        background: rgba(59,130,246,.15);
        color: #60a5fa;
        border-radius: .375rem;
        padding: .2rem .55rem;
        font-size: .8rem; font-weight: 700;
        font-family: 'Courier New', monospace;
    }
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        color: #475569;
    }
    .empty-state i { font-size: 3.5rem; display: block; margin-bottom: 1rem; opacity: .4; }
    .empty-state p  { color: #64748b; margin: 0; }
    @@media print {
        .filter-card, .no-print { display: none !important; }
        .report-hero { background: none; border: none; padding: 0; margin-bottom: 1rem; }
        body { background: #fff !important; color: #000 !important; }
        .stat-card { border: 1px solid #ddd; }
    }
</style>

<!-- Encabezado del reporte -->
<div class="report-hero no-print-bg">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-graph-up-arrow me-2 text-primary"></i>Reporte de Ventas</h2>
        <div class="d-flex align-items-center gap-2 flex-wrap mt-1">
            <span class="tag-filter"><i class="bi bi-calendar3"></i>@ViewBag.DisplayDate</span>
            <span class="tag-filter"><i class="bi bi-clock"></i>@ViewBag.DisplayShift</span>
            <span class="tag-filter" style="background:rgba(16,185,129,.1);border-color:rgba(16,185,129,.3);color:#6ee7b7;">
                <i class="bi bi-receipt"></i>@count ticket@(count != 1 ? "s" : "")
            </span>
        </div>
    </div>
    <a asp-action="ReportPdf" asp-controller="Sales"
       asp-route-date="@ViewBag.Date" asp-route-shift="@ViewBag.Shift"
       target="_blank"
       class="btn no-print"
       style="background:linear-gradient(135deg,#1d4ed8,#1e3a5f);color:#fff;font-weight:600;border:none;">
        <i class="bi bi-file-earmark-pdf me-2"></i>Generar PDF
    </a>
</div>

<!-- Filtros -->
<div class="filter-card no-print">
    <form asp-action="Reports" asp-controller="Sales" method="get" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">FECHA</label>
            <input type="date" name="date" class="form-control" value="@ViewBag.Date" />
        </div>
        <div class="col-md-4">
            <label class="form-label">TURNO</label>
            <select name="shift" class="form-select" asp-items="shiftItems"></select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-fill">
                <i class="bi bi-funnel-fill me-2"></i>Generar reporte
            </button>
            <a asp-action="Reports" asp-controller="Sales" class="btn"
               style="background:rgba(255,255,255,.06);color:#94a3b8;border:1px solid rgba(255,255,255,.1);"
               title="Limpiar filtros">
                <i class="bi bi-x-lg"></i>
            </a>
        </div>
    </form>
</div>

<!-- Tarjetas de estadísticas -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-currency-dollar"></i></div>
            <div>
                <div class="stat-label">Total recaudado</div>
                <div class="stat-value">Q @total.ToString("N2")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-receipt-cutoff"></i></div>
            <div>
                <div class="stat-label">Tickets emitidos</div>
                <div class="stat-value">@count</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-bar-chart-line"></i></div>
            <div>
                <div class="stat-label">Promedio por venta</div>
                <div class="stat-value">Q @promedio.ToString("N2")</div>
            </div>
        </div>
    </div>
</div>

<!-- Tabla de ventas -->
<div class="glass-card" style="padding:0;overflow:hidden;">
    <div class="table-responsive">
        <table class="table table-report mb-0">
            <thead>
                <tr>
                    <th>Ticket</th>
                    <th>Hora</th>
                    <th>NIT</th>
                    <th>Cliente</th>
                    <th class="text-center">Uds.</th>
                    <th class="text-end">Total</th>
                    <th class="text-end no-print">Recibo</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-clipboard-x"></i>
                                <p>No hay ventas registradas para<br><strong>@ViewBag.DisplayDate — @ViewBag.DisplayShift</strong></p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var sale in Model)
                    {
                        <tr>
                            <td><span class="ticket-badge">#@sale.Id.ToString("D5")</span></td>
                            <td style="color:#94a3b8;">@sale.SaleDate.ToString("HH:mm")</td>
                            <td style="color:#94a3b8;font-size:.82rem;">@sale.CustomerNit</td>
                            <td class="fw-semibold">@sale.CustomerName</td>
                            <td class="text-center">
                                <span class="status-badge" style="background:rgba(59,130,246,.12);color:#60a5fa;">
                                    @sale.SaleDetails.Sum(d => d.Quantity)
                                </span>
                            </td>
                            <td class="text-end fw-bold" style="color:#10b981;">Q @sale.TotalAmount.ToString("N2")</td>
                            <td class="text-end no-print">
                                <a asp-action="Receipt" asp-route-id="@sale.Id" target="_blank"
                                   class="btn btn-sm" title="Ver recibo"
                                   style="background:rgba(59,130,246,.1);color:#60a5fa;border:1px solid rgba(59,130,246,.2);">
                                    <i class="bi bi-receipt"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    <tr style="background:rgba(15,23,42,.5);">
                        <td colspan="5" class="text-end fw-bold" style="color:#64748b;font-size:.8rem;letter-spacing:.05em;text-transform:uppercase;padding:.85rem 1rem;">
                            Total del período
                        </td>
                        <td class="text-end fw-bold fs-5" style="color:#10b981;padding:.85rem 1rem;">Q @total.ToString("N2")</td>
                        <td class="no-print"></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
